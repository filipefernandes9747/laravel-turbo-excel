{
    "name": "filipefernandes/laravel-turbo-excel",
    "description": "Blazing fast, memory-efficient Excel and CSV exports for Laravel powerd by OpenSpout.",
    "version": "0.0.7",
    "keywords": [
        "laravel",
        "excel",
        "xlsx",
        "csv",
        "export",
        "openspout",
        "fast",
        "stream"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Filipe Fernandes",
            "email": "filipe9747@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/bus": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "openspout/openspout": "^4.23"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "TurboExcel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TurboExcel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TurboExcel\\TurboExcelServiceProvider"
            ],
            "aliases": {
                "TurboExcel": "TurboExcel\\Facades\\TurboExcel"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
